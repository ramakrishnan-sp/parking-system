# Backend base URL (do NOT include /api/v1 — the client appends it)
# Recommended for LAN testing: leave blank so the app uses http://<current-host>:8000
# Or set explicitly, e.g. http://192.168.0.110:8000
VITE_API_URL=

# Razorpay public key (used by the payment flow)
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Optional (only needed if you kept any Gemini AI features)
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Optional
APP_URL=http://localhost:3000
